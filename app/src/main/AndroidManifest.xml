<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.eevdf.scheduler">

    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- External storage for multi-user sync (read/write shared folder)
         API 26-29: READ/WRITE_EXTERNAL_STORAGE for direct file access.
         API 30+  : MANAGE_EXTERNAL_STORAGE bypasses scoped storage; user is
                    prompted in MultiUserSyncActivity; falls back to SAF if denied. -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <!-- Auto Switch: call detection -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    
    <application
        android:name=".EEVDFApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:name=".ui.task.MainActivity"
            android:exported="true"
            android:resizeableActivity="true"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation|keyboardHidden|density">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.task.AddTaskActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.task.MainActivity" />

        <!--
            Full-screen alarm activity — shown over lock screen when timer expires.
            showWhenLocked + turnScreenOn handled in code for API 26 compat.
        -->
        <!--
            Settings screen — import / export data backup.
        -->
        <activity
            android:name=".ui.stats.StatsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.task.MainActivity" />

        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.task.MainActivity" />

        <activity
            android:name=".ui.backup.DataBackupActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.settings.SettingsActivity" />

        <activity
            android:name=".ui.settings.ProfileSettingsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.settings.SoundVibrationActivity" />

        <activity
            android:name=".ui.settings.SoundVibrationActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.settings.SettingsActivity" />

        <!-- Multi-user live sync settings screen -->
        <activity
            android:name=".ui.sync.MultiUserSyncActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.settings.SettingsActivity" />

        <!-- Auto Switch settings screen -->
        <activity
            android:name=".ui.autoswitch.AutoSwitchActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.settings.SettingsActivity" />

        <!-- UI Customization settings screen -->
        <activity
            android:name=".ui.settings.UiCustomizationActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation|keyboardHidden|density"
            android:parentActivityName=".ui.settings.SettingsActivity" />

        <!-- Auto Switch: phone call state receiver -->
        <receiver
            android:name=".ui.autoswitch.CallStateReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

        <!--
            Full-screen alarm activity — shown over lock screen when timer expires.
            showWhenLocked + turnScreenOn handled in code for API 26 compat.
        -->
        <activity
            android:name=".ui.alarm.AlarmActivity"
            android:exported="false"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance" />

        <!-- Receives the Stop action from the expired-timer notification -->\n        <receiver
            android:name=".ui.alarm.AlarmStopReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.eevdf.scheduler.ACTION_TIMER_EXPIRED" />
            </intent-filter>
        </receiver>

        <!-- Receives AlarmManager.setAlarmClock() callback — Doze-immune timer trigger -->
        <receiver
            android:name=".ui.alarm.TimerAlarmReceiver"
            android:exported="false" />

        <!--
            Foreground service that holds WakeLock and launches AlarmActivity.
            Uses media_playback type which is allowed to start activities from background
            on Android 12+ without special permissions.
        -->
        <service
            android:name=".ui.alarm.AlarmForegroundService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

    </application>

</manifest>
