<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/screenBackground</item>
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Used by GroupPickerDialog — a min-width Material dialog theme,
         declared locally so it resolves via this app's generated R.style. -->
    <style name="AppTheme.GroupPickerDialog" parent="Theme.MaterialComponents.Light.Dialog.MinWidth" />

</resources>
