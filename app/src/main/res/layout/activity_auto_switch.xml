<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/autoSwitchToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/colorPrimary"
            app:titleTextColor="@android:color/white" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRIGGERS"
                android:textSize="11sp"
                android:textColor="@color/textSecondary"
                android:fontFamily="sans-serif-medium"
                android:paddingBottom="12dp"
                android:letterSpacing="0.08" />

            <!-- Call Detection card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Toggle row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Call Detection"
                                android:textSize="16sp"
                                android:textColor="@color/textPrimary"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pause and resume tasks automatically during phone calls"
                                android:textSize="13sp"
                                android:textColor="@color/textSecondary"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchCallDetection"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp" />

                    </LinearLayout>

                    <!-- Permission status badge -->
                    <TextView
                        android:id="@+id/tvPermissionStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phone permission not granted"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp" />

                    <!-- Task picker section (shown when enabled) -->
                    <LinearLayout
                        android:id="@+id/layoutCallTaskPicker"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Switch to task during call"
                            android:textSize="14sp"
                            android:textColor="@color/textPrimary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Search by name or tap to browse all tasks"
                            android:textSize="12sp"
                            android:textColor="@color/textSecondary"
                            android:layout_marginBottom="10dp" />

                        <AutoCompleteTextView
                            android:id="@+id/actvCallTask"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Search task…"
                            android:inputType="text"
                            android:completionThreshold="1"
                            android:padding="12dp"
                            android:textSize="14sp"
                            android:background="@drawable/bg_edit_text"
                            android:imeOptions="actionDone" />

                        <TextView
                            android:id="@+id/tvCallTaskHint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="#2196F3"
                            android:layout_marginTop="6dp"
                            android:visibility="gone" />

                    </LinearLayout>

                    <!-- Behavior description (always visible) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#F5F5F5"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="When a call starts"
                            android:textSize="12sp"
                            android:textColor="@color/textSecondary"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="→ Current task pauses, switches to assigned call task"
                            android:textSize="12sp"
                            android:textColor="@color/textSecondary"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="When the call ends"
                            android:textSize="12sp"
                            android:textColor="@color/textSecondary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="→ Returns to previous task and resumes"
                            android:textSize="12sp"
                            android:textColor="@color/textSecondary"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>


            <!-- ── QUICK SWITCH section ───────────────────────────────────────── -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QUICK SWITCH"
                android:textSize="11sp"
                android:textColor="@color/textSecondary"
                android:fontFamily="sans-serif-medium"
                android:paddingBottom="12dp"
                android:letterSpacing="0.08" />

            <!-- Quick Switch card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Toggle row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Quick Switch"
                                android:textSize="16sp"
                                android:textColor="@color/textPrimary"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Switch tasks in the background without opening the app"
                                android:textSize="13sp"
                                android:textColor="@color/textSecondary"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchQuickSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp" />

                    </LinearLayout>

                    <!-- Info box -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#F5F5F5"
                        android:padding="12dp"
                        android:layout_marginTop="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="When OFF"
                            android:textSize="12sp"
                            android:textColor="@color/textSecondary"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="→ Task switch fires only while the app is open"
                            android:textSize="12sp"
                            android:textColor="@color/textSecondary"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="When ON"
                            android:textSize="12sp"
                            android:textColor="@color/textSecondary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="→ Switch happens in background; hover bubble available"
                            android:textSize="12sp"
                            android:textColor="@color/textSecondary"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Hover Bubble section — only shown when Quick Switch is ON -->
            <LinearLayout
                android:id="@+id/layoutQuickSwitchOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOVER BUBBLE"
                android:textSize="11sp"
                android:textColor="@color/textSecondary"
                android:fontFamily="sans-serif-medium"
                android:paddingBottom="12dp"
                android:letterSpacing="0.08" />

            <!-- Hover Bubble card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Toggle row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hover Bubble"
                                android:textSize="16sp"
                                android:textColor="@color/textPrimary"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Show a floating bubble during calls on configured apps"
                                android:textSize="13sp"
                                android:textColor="@color/textSecondary"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchBubble"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp" />

                    </LinearLayout>

                    <!-- Overlay permission badge -->
                    <TextView
                        android:id="@+id/tvOverlayPermStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Overlay permission not granted"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp" />

                    <!-- Usage-stats permission badge -->
                    <TextView
                        android:id="@+id/tvUsageStatsPermStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Usage access not granted"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp" />

                    <!-- Options shown only when bubble is enabled -->
                    <LinearLayout
                        android:id="@+id/layoutBubbleOptions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <!-- Position: Fixed vs Draggable -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bubble position"
                            android:textSize="14sp"
                            android:textColor="@color/textPrimary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="8dp" />

                        <RadioGroup
                            android:id="@+id/rgBubblePosition"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">

                            <RadioButton
                                android:id="@+id/rbFixed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fixed"
                                android:textSize="14sp"
                                android:layout_marginEnd="24dp" />

                            <RadioButton
                                android:id="@+id/rbDraggable"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Draggable"
                                android:textSize="14sp" />

                        </RadioGroup>

                        <!-- App list config -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Active on these apps"
                            android:textSize="14sp"
                            android:textColor="@color/textPrimary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bubble appears only when one of these apps is in the foreground during a call. Leave empty to show on all apps."
                            android:textSize="12sp"
                            android:textColor="@color/textSecondary"
                            android:layout_marginBottom="10dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnConfigureApps"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Configure Apps"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvConfiguredApps"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="All apps (no filter)"
                            android:textSize="12sp"
                            android:textColor="@color/textSecondary" />

                    </LinearLayout>

                    <!-- How-it-works footer -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#F5F5F5"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bubble colour"
                            android:textSize="12sp"
                            android:textColor="@color/textSecondary"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="● Green — call task timer is running"
                            android:textSize="12sp"
                            android:textColor="@color/textSecondary"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="● Amber — call task timer is paused"
                            android:textSize="12sp"
                            android:textColor="@color/textSecondary"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap bubble"
                            android:textSize="12sp"
                            android:textColor="@color/textSecondary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="→ Toggles pause / resume on the assigned call task"
                            android:textSize="12sp"
                            android:textColor="@color/textSecondary"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            </LinearLayout><!-- end layoutQuickSwitchOptions -->

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
