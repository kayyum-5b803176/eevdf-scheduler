<?xml version="1.0" encoding="utf-8"?>
<!--
  SCHED_DEADLINE sub-section — runtime, deadline, period duration fields.

  This layout is included inside section_add_task_scheduler.xml.
  The root LinearLayout carries android:id="@+id/layoutDlFields" so
  AddTaskSchedulerSection.kt can show/hide it when dl_sched_class is selected.

  All three fields use the NdNhNmNs format parsed by parseQuotaInput().
  Validation rules (runtime ≤ deadline; period defaults to deadline when empty)
  live in AddTaskSaveHandler.kt.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutDlFields"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:visibility="gone">

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="14dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SCHED_DEADLINE Parameters"
        android:textSize="13sp"
        android:textColor="#212121"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Format: NdNhNmNs  e.g. 30m · 2h · 10s (1s–365d)"
        android:textSize="11sp"
        android:textColor="#9E9E9E"
        android:layout_marginBottom="14dp" />

    <!-- Runtime -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Runtime (sched_runtime)"
            android:textSize="13sp"
            android:textColor="#212121"
            android:fontFamily="sans-serif-medium" />
        <TextView
            android:id="@+id/tvDlRuntimePreview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="@color/colorPrimary"
            android:textStyle="bold" />
    </LinearLayout>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="How long the task may run per period"
        android:textSize="11sp"
        android:textColor="#9E9E9E"
        android:layout_marginBottom="6dp" />
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Runtime  (e.g. 10m, 1h, 30s)"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_marginBottom="16dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDlRuntime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:digits="0123456789dDhHmMsS "
            android:maxLength="20" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Deadline -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Deadline (sched_deadline)"
            android:textSize="13sp"
            android:textColor="#212121"
            android:fontFamily="sans-serif-medium" />
        <TextView
            android:id="@+id/tvDlDeadlinePreview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="@color/colorPrimary"
            android:textStyle="bold" />
    </LinearLayout>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Relative deadline from period start; runtime must be ≤ deadline"
        android:textSize="11sp"
        android:textColor="#9E9E9E"
        android:layout_marginBottom="6dp" />
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Deadline  (e.g. 30m, 2h, 1d)"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_marginBottom="16dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDlDeadline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:digits="0123456789dDhHmMsS "
            android:maxLength="20" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Period (optional) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Period (sched_period) — optional"
            android:textSize="13sp"
            android:textColor="#212121"
            android:fontFamily="sans-serif-medium" />
        <TextView
            android:id="@+id/tvDlPeriodPreview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="@color/colorPrimary"
            android:textStyle="bold" />
    </LinearLayout>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Replenishment period; leave empty to default to deadline value"
        android:textSize="11sp"
        android:textColor="#9E9E9E"
        android:layout_marginBottom="6dp" />
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Period  (e.g. 1d, 7d — empty = same as deadline)"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDlPeriod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:digits="0123456789dDhHmMsS "
            android:maxLength="20" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/tvDlError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="#F44336"
        android:layout_marginTop="6dp"
        android:visibility="gone" />

</LinearLayout>
