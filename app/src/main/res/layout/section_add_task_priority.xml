<?xml version="1.0" encoding="utf-8"?>
<!--
  Schedule Priority card — 1–7 integer slider with live band description.

  tvPriorityLabel  — updated by AddTaskCategoryPrioritySection.updatePriorityDisplay()
  tvPriorityInfo   — updated by AddTaskCategoryPrioritySection.updatePriorityDisplay();
                     shows override text when pinned share is active.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header row: section title + live value label -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Schedule Priority"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary" />

            <TextView
                android:id="@+id/tvPriorityLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Priority: 4"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#212121" />
        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderPriority"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:valueFrom="1"
            android:valueTo="7"
            android:stepSize="1"
            android:value="4"
            app:haloColor="@color/colorPrimary"
            app:thumbColor="@color/colorPrimary"
            app:trackColorActive="@color/colorPrimary" />

        <!-- Scale end-labels -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1 (Low)"
                android:textSize="10sp"
                android:textColor="#9E9E9E" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7 (Critical)"
                android:textSize="10sp"
                android:textColor="#9E9E9E" />
        </LinearLayout>

        <!-- Band description / pinned-share override notice -->
        <TextView
            android:id="@+id/tvPriorityInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text=""
            android:textSize="12sp"
            android:textColor="#616161"
            android:background="#F3F3F3"
            android:padding="10dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
