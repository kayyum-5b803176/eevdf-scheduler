<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/multiUserSyncToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/white"
        android:elevation="4dp"
        app:titleTextColor="@color/textPrimary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- ── Enable toggle ────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enable Multiuser Sync"
                        android:textSize="16sp"
                        android:textColor="@color/textPrimary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Share task &amp; timer state in real-time with other users"
                        android:textSize="12sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchSyncEnable"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- ── Divider ───────────────────────────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="16dp" />

            <!-- ── Sync status line ──────────────────────────────────────────── -->
            <TextView
                android:id="@+id/tvSyncStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sync disabled"
                android:textSize="13sp"
                android:textColor="@color/textSecondary"
                android:layout_marginBottom="20dp" />

            <!-- ── Folder row (hidden when sync disabled) ────────────────────── -->
            <LinearLayout
                android:id="@+id/layoutSyncFolderRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sync Folder"
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All devices must point to the same folder (e.g. a shared network drive or cloud-synced directory)."
                    android:textSize="12sp"
                    android:textColor="@color/textSecondary"
                    android:layout_marginBottom="8dp" />

                <!-- Current folder path display -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F5F5F5">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_agenda"
                            android:layout_marginEnd="8dp"
                            android:tint="@color/textSecondary" />

                        <TextView
                            android:id="@+id/tvSyncFolderPath"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="No folder selected"
                            android:textSize="13sp"
                            android:textColor="@color/textPrimary"
                            android:singleLine="true"
                            android:ellipsize="start" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickSyncFolder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Choose Sync Folder"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manual Sync"
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sync happens automatically every 3 seconds. Use this to force an immediate sync."
                    android:textSize="12sp"
                    android:textColor="@color/textSecondary"
                    android:layout_marginBottom="8dp" />

                <!-- ── Write stats card ──────────────────────────────────────── -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Storage Write Stats"
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Page-diff mode writes only changed 4 KB blocks. Green = working efficiently."
                    android:textSize="12sp"
                    android:textColor="@color/textSecondary"
                    android:layout_marginBottom="8dp" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardWriteStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F5F5F5">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <!-- Access mode badge row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Access mode"
                                android:textSize="12sp"
                                android:textColor="@color/textSecondary" />

                            <TextView
                                android:id="@+id/tvAccessMode"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="12sp"
                                android:textColor="@color/textPrimary"
                                android:textStyle="bold"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp"
                                android:background="@drawable/badge_bg"
                                android:backgroundTint="@color/syncDotDisabled" />
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#E0E0E0"
                            android:layout_marginBottom="10dp" />

                        <!-- Last export row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Last export"
                                android:textSize="12sp"
                                android:textColor="@color/textSecondary" />

                            <TextView
                                android:id="@+id/tvLastExportTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="12sp"
                                android:textColor="@color/textPrimary" />
                        </LinearLayout>

                        <!-- DB size row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="DB size"
                                android:textSize="12sp"
                                android:textColor="@color/textSecondary" />

                            <TextView
                                android:id="@+id/tvDbSize"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="12sp"
                                android:textColor="@color/textPrimary" />
                        </LinearLayout>

                        <!-- Written / skipped row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Last write"
                                android:textSize="12sp"
                                android:textColor="@color/textSecondary" />

                            <TextView
                                android:id="@+id/tvBytesWritten"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="12sp"
                                android:textColor="@color/textPrimary" />
                        </LinearLayout>

                        <!-- Pages written / skipped (only shown in direct mode) -->
                        <LinearLayout
                            android:id="@+id/rowPageStats"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="6dp"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Pages written / skipped"
                                android:textSize="12sp"
                                android:textColor="@color/textSecondary" />

                            <TextView
                                android:id="@+id/tvPageStats"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="12sp"
                                android:textColor="@color/textPrimary" />
                        </LinearLayout>

                        <!-- Write ratio progress bar -->
                        <LinearLayout
                            android:id="@+id/rowWriteRatio"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="6dp"
                            android:visibility="gone">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="3dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Write ratio"
                                    android:textSize="12sp"
                                    android:textColor="@color/textSecondary" />

                                <TextView
                                    android:id="@+id/tvWriteRatioPct"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textSize="12sp"
                                    android:textColor="@color/textPrimary" />
                            </LinearLayout>

                            <ProgressBar
                                android:id="@+id/progressWriteRatio"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="6dp"
                                android:max="100"
                                android:progress="0"
                                android:progressTint="@color/syncDotOK"
                                android:progressBackgroundTint="#E0E0E0" />
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#E0E0E0"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="10dp" />

                        <!-- Session totals -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Session exports"
                                android:textSize="12sp"
                                android:textColor="@color/textSecondary" />

                            <TextView
                                android:id="@+id/tvSessionExports"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="12sp"
                                android:textColor="@color/textPrimary" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Session total written"
                                android:textSize="12sp"
                                android:textColor="@color/textSecondary" />

                            <TextView
                                android:id="@+id/tvSessionTotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 B"
                                android:textSize="12sp"
                                android:textColor="@color/textPrimary" />
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ── Sync Now button (also hidden when disabled) ───────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSyncNow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sync Now"
                android:visibility="gone"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <!-- ── How it works info ─────────────────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How Multiuser Sync Works"
                android:textSize="14sp"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• All devices share a single JSON file in the sync folder.\n\n• When User A starts a timer, the change is written to the shared file within 1 second.\n\n• User B's app picks up the change within 3 seconds and updates its UI automatically.\n\n• If the sync folder is unavailable, the app continues working normally — the error icon in the toolbar will show in red.\n\n• The sync icon turns green when everything is working, and red when there is a problem."
                android:textSize="12sp"
                android:textColor="@color/textSecondary"
                android:lineSpacingMultiplier="1.3" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
