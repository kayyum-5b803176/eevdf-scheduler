<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ── Period Selector ──────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ANALYSIS PERIOD"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp" />
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupPeriod"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip7d"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7 Days"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:checked="true" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip30d"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30 Days"
                        style="@style/Widget.MaterialComponents.Chip.Choice" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip90d"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="90 Days"
                        style="@style/Widget.MaterialComponents.Chip.Choice" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All Time"
                        style="@style/Widget.MaterialComponents.Chip.Choice" />
                </com.google.android.material.chip.ChipGroup>
                <TextView
                    android:id="@+id/tvChartsPeriodLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Showing last 7 days"
                    android:textSize="11sp"
                    android:textColor="@color/colorPrimary"
                    android:layout_marginTop="6dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Pie Chart: Time Distribution ─────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TIME DISTRIBUTION"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Share of total runtime per task"
                    android:textSize="12sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="10dp" />
                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pieChart"
                    android:layout_width="match_parent"
                    android:layout_height="280dp" />
                <TextView
                    android:id="@+id/tvPieEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No data in this period"
                    android:textSize="13sp"
                    android:textColor="#BDBDBD"
                    android:gravity="center"
                    android:visibility="gone"
                    android:padding="20dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Bar Chart: Daily Activity ────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DAILY ACTIVITY"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total hours tracked per day"
                    android:textSize="12sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="10dp" />
                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/barChartDaily"
                    android:layout_width="match_parent"
                    android:layout_height="240dp" />
                <TextView
                    android:id="@+id/tvBarDailyEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No daily data in this period"
                    android:textSize="13sp"
                    android:textColor="#BDBDBD"
                    android:gravity="center"
                    android:visibility="gone"
                    android:padding="20dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Line Chart: Task Trends ──────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TASK TRENDS"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daily runtime trend for top tasks (hours)"
                    android:textSize="12sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="10dp" />
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/lineChartTrend"
                    android:layout_width="match_parent"
                    android:layout_height="260dp" />
                <TextView
                    android:id="@+id/tvLineEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Not enough data for trend analysis"
                    android:textSize="13sp"
                    android:textColor="#BDBDBD"
                    android:gravity="center"
                    android:visibility="gone"
                    android:padding="20dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Horizontal Bar: Run Count per Task ───────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RUN FREQUENCY"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Number of sessions started per task"
                    android:textSize="12sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="10dp" />
                <com.github.mikephil.charting.charts.HorizontalBarChart
                    android:id="@+id/barChartRunCount"
                    android:layout_width="match_parent"
                    android:layout_height="240dp" />
                <TextView
                    android:id="@+id/tvBarCountEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No run data in this period"
                    android:textSize="13sp"
                    android:textColor="#BDBDBD"
                    android:gravity="center"
                    android:visibility="gone"
                    android:padding="20dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Radar Chart: Weekday Pattern ─────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WEEKDAY PATTERN"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total runtime by day of week"
                    android:textSize="12sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="10dp" />
                <com.github.mikephil.charting.charts.RadarChart
                    android:id="@+id/radarChartWeekday"
                    android:layout_width="match_parent"
                    android:layout_height="280dp" />
                <TextView
                    android:id="@+id/tvRadarEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Not enough weekday data yet"
                    android:textSize="13sp"
                    android:textColor="#BDBDBD"
                    android:gravity="center"
                    android:visibility="gone"
                    android:padding="20dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Scatter Chart: Session Duration Distribution ──────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SESSION DURATION DISTRIBUTION"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Each dot is one session (x=day offset, y=duration min)"
                    android:textSize="12sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="10dp" />
                <com.github.mikephil.charting.charts.ScatterChart
                    android:id="@+id/scatterChart"
                    android:layout_width="match_parent"
                    android:layout_height="240dp" />
                <TextView
                    android:id="@+id/tvScatterEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No session data in this period"
                    android:textSize="13sp"
                    android:textColor="#BDBDBD"
                    android:gravity="center"
                    android:visibility="gone"
                    android:padding="20dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <View android:layout_width="match_parent" android:layout_height="16dp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
