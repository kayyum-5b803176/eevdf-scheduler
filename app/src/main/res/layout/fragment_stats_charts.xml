<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ── Analysis Window ───────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ANALYSIS WINDOW"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="8dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Range (e.g. 7d, 24h, 30m)"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        android:layout_marginEnd="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etChartsWindowRange"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:digits="0123456789dDhHmMsS "
                            android:maxLength="20"
                            android:text="7d" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnChartsApplyWindow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Apply"
                        android:textSize="13sp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                </LinearLayout>
                <TextView
                    android:id="@+id/tvChartsPeriodLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Showing last 7 days"
                    android:textSize="11sp"
                    android:textColor="@color/colorPrimary"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <!-- ── Bar Chart: Daily Activity ────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DAILY ACTIVITY"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total hours tracked per day"
                    android:textSize="12sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="10dp" />
                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/barChartDaily"
                    android:layout_width="match_parent"
                    android:layout_height="240dp" />
                <TextView
                    android:id="@+id/tvBarDailyEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No daily data in this period"
                    android:textSize="13sp"
                    android:textColor="#BDBDBD"
                    android:gravity="center"
                    android:visibility="gone"
                    android:padding="20dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Line Chart: Task Trends ──────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TASK TRENDS"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daily runtime trend for top tasks (hours)"
                    android:textSize="12sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="10dp" />
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/lineChartTrend"
                    android:layout_width="match_parent"
                    android:layout_height="260dp" />
                <TextView
                    android:id="@+id/tvLineEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Not enough data for trend analysis"
                    android:textSize="13sp"
                    android:textColor="#BDBDBD"
                    android:gravity="center"
                    android:visibility="gone"
                    android:padding="20dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Horizontal Bar: Run Count per Task ───────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RUN FREQUENCY"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Number of sessions started per task"
                    android:textSize="12sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="10dp" />
                <com.github.mikephil.charting.charts.HorizontalBarChart
                    android:id="@+id/barChartRunCount"
                    android:layout_width="match_parent"
                    android:layout_height="240dp" />
                <TextView
                    android:id="@+id/tvBarCountEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No run data in this period"
                    android:textSize="13sp"
                    android:textColor="#BDBDBD"
                    android:gravity="center"
                    android:visibility="gone"
                    android:padding="20dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Radar Chart: Weekday Pattern ─────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WEEKDAY PATTERN"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total runtime by day of week"
                    android:textSize="12sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="10dp" />
                <com.github.mikephil.charting.charts.RadarChart
                    android:id="@+id/radarChartWeekday"
                    android:layout_width="match_parent"
                    android:layout_height="280dp" />
                <TextView
                    android:id="@+id/tvRadarEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Not enough weekday data yet"
                    android:textSize="13sp"
                    android:textColor="#BDBDBD"
                    android:gravity="center"
                    android:visibility="gone"
                    android:padding="20dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Scatter Chart: Session Duration Distribution ──────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SESSION DURATION DISTRIBUTION"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Each dot is one session (x=day offset, y=duration min)"
                    android:textSize="12sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="10dp" />
                <com.github.mikephil.charting.charts.ScatterChart
                    android:id="@+id/scatterChart"
                    android:layout_width="match_parent"
                    android:layout_height="240dp" />
                <TextView
                    android:id="@+id/tvScatterEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No session data in this period"
                    android:textSize="13sp"
                    android:textColor="#BDBDBD"
                    android:gravity="center"
                    android:visibility="gone"
                    android:padding="20dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <View android:layout_width="match_parent" android:layout_height="16dp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
