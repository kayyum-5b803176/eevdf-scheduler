<?xml version="1.0" encoding="utf-8"?>
<!--
    Floating call-state bubble overlay.

    Outer circle: semi-transparent dark background (bubble_background drawable).
    Inner dot:    coloured by BubbleOverlayService.updateDotColor() at runtime:
                    green  #4CAF50 — call task timer is running
                    amber  #FF9800 — call task timer is paused

    The whole 52dp FrameLayout is the touch target (click = toggle, drag = reposition).
    WindowManager adds this view with FLAG_NOT_FOCUSABLE so the keyboard and
    back-press handling of the foreground app are never intercepted.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="52dp"
    android:layout_height="52dp">

    <!-- Dark semi-transparent circle background -->
    <View
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/bubble_background" />

    <!-- Timer-state dot — tinted at runtime by BubbleOverlayService -->
    <View
        android:id="@+id/bubbleDot"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_gravity="center"
        android:background="@drawable/ic_sync_dot" />

</FrameLayout>
