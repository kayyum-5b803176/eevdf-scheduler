<?xml version="1.0" encoding="utf-8"?>
<!--
  SCHED_FIFO / SCHED_RR sub-section — RT priority slider, policy spinner,
  active-days checkboxes, activation time, slice timeout.

  This layout is included inside section_add_task_scheduler.xml.
  The root LinearLayout carries android:id="@+id/layoutRtFields" so
  AddTaskSchedulerSection.kt can show/hide it when rt_sched_class is selected.

  Active-days bitmask: bits are defined as DAY_SUN … DAY_SAT in RtScheduler.kt.
  Slice-timeout format: NdNhNmNs, parsed by parseQuotaInput(); required field.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutRtFields"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginTop="12dp"
    android:visibility="gone">

    <!-- RT Priority slider -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="RT Priority (1 = lowest, 99 = highest)"
        android:textSize="13sp"
        android:textColor="#616161" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp">

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderRtPriority"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:valueFrom="1"
            android:valueTo="99"
            android:stepSize="1"
            android:value="50" />

        <TextView
            android:id="@+id/tvRtPriorityValue"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:text="50"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="end" />
    </LinearLayout>

    <!-- Policy spinner -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Policy"
        android:textSize="13sp"
        android:textColor="#616161"
        android:layout_marginTop="10dp" />

    <Spinner
        android:id="@+id/spinnerRtPolicy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp" />

    <!-- Active days checkboxes -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Active days"
        android:textSize="13sp"
        android:textColor="#616161"
        android:layout_marginTop="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <CheckBox
            android:id="@+id/cbRtSun"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sun"
            android:textSize="11sp" />

        <CheckBox
            android:id="@+id/cbRtMon"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mon"
            android:textSize="11sp" />

        <CheckBox
            android:id="@+id/cbRtTue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tue"
            android:textSize="11sp" />

        <CheckBox
            android:id="@+id/cbRtWed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Wed"
            android:textSize="11sp" />

        <CheckBox
            android:id="@+id/cbRtThu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Thu"
            android:textSize="11sp" />

        <CheckBox
            android:id="@+id/cbRtFri"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Fri"
            android:textSize="11sp" />

        <CheckBox
            android:id="@+id/cbRtSat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sat"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Activation time HH MM SS -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Activation time (HH  MM  SS)"
        android:textSize="13sp"
        android:textColor="#616161"
        android:layout_marginTop="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="HH">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRtHour"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="0" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:hint="MM">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRtMinute"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="00" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:hint="SS">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRtSecond"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="00" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- Slice timeout -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Slice timeout (e.g. 30m, 2h, 1d)"
        android:textSize="13sp"
        android:textColor="#616161"
        android:layout_marginTop="10dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:hint="Duration">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etRtSliceTimeout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/tvRtSliceTimeoutPreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="#1B5E20"
        android:layout_marginTop="2dp" />

    <TextView
        android:id="@+id/tvRtError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="#F44336"
        android:layout_marginTop="6dp"
        android:visibility="gone" />

</LinearLayout>
