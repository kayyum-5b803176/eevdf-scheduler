<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/profileSettingsToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/white"
        android:elevation="4dp"
        app:titleTextColor="@color/textPrimary" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/profileTabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabSelectedTextColor="@color/colorPrimary"
        app:tabIndicatorColor="@color/colorPrimary"
        app:tabTextColor="@color/textSecondary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- ══ SOUND ══════════════════════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SOUND"
                android:textSize="11sp" android:letterSpacing="0.12"
                android:textColor="@color/colorPrimary"
                android:fontFamily="sans-serif-medium"
                android:paddingBottom="12dp" />

            <!-- Timer sound -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp" app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Timer Sound" android:textSize="16sp"
                                android:textColor="@color/textPrimary" android:fontFamily="sans-serif-medium" />
                            <TextView android:id="@+id/tvProfileSoundName"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="System alarm tone" android:textSize="13sp"
                                android:textColor="@color/textSecondary" android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnProfilePickSound"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Choose"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Sound timeout -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp" app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Sound Timeout"
                            android:textSize="16sp" android:textColor="@color/textPrimary"
                            android:fontFamily="sans-serif-medium" />
                        <TextView android:id="@+id/tvProfileSoundTimeoutLabel"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="1 min" android:textSize="14sp"
                            android:textColor="@color/colorPrimary" android:textStyle="bold" />
                    </LinearLayout>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="How long sound plays after timer expires (0 = no timeout)"
                        android:textSize="12sp" android:textColor="@color/textSecondary"
                        android:layout_marginTop="2dp" android:layout_marginBottom="8dp" />
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderProfileSoundTimeout"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:valueFrom="0" android:valueTo="900" android:stepSize="15" android:value="60"
                        app:thumbColor="@color/colorPrimary" app:trackColorActive="@color/colorPrimary" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="No timeout" android:textSize="10sp" android:textColor="#9E9E9E"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15 min" android:textSize="10sp" android:textColor="#9E9E9E"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Default volume -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp" app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Default Volume"
                            android:textSize="16sp" android:textColor="@color/textPrimary"
                            android:fontFamily="sans-serif-medium" />
                        <TextView android:id="@+id/tvProfileVolumeLabel"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="80%" android:textSize="14sp"
                            android:textColor="@color/colorPrimary" android:textStyle="bold" />
                    </LinearLayout>
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderProfileVolume"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:valueFrom="0" android:valueTo="100" android:stepSize="5" android:value="80"
                        app:thumbColor="@color/colorPrimary" app:trackColorActive="@color/colorPrimary" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0%" android:textSize="10sp" android:textColor="#9E9E9E"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100%" android:textSize="10sp" android:textColor="#9E9E9E"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Gradual volume increase -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp" app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Gradual Volume Increase"
                            android:textSize="16sp" android:textColor="@color/textPrimary"
                            android:fontFamily="sans-serif-medium" />
                        <TextView android:id="@+id/tvProfileFadeInLabel"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Off" android:textSize="14sp"
                            android:textColor="@color/colorPrimary" android:textStyle="bold" />
                    </LinearLayout>
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderProfileFadeIn"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:valueFrom="0" android:valueTo="300" android:stepSize="15" android:value="0"
                        app:thumbColor="@color/colorPrimary" app:trackColorActive="@color/colorPrimary" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Off" android:textSize="10sp" android:textColor="#9E9E9E"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5 min" android:textSize="10sp" android:textColor="#9E9E9E"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ VIBRATION ══════════════════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="VIBRATION"
                android:textSize="11sp" android:letterSpacing="0.12"
                android:textColor="@color/colorPrimary" android:fontFamily="sans-serif-medium"
                android:paddingBottom="12dp" />

            <!-- Vibration pattern spinner -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp" app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Vibration Pattern" android:textSize="16sp"
                        android:textColor="@color/textPrimary" android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="12dp" />
                    <Spinner
                        android:id="@+id/spinnerProfileVibPattern"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="@drawable/abc_spinner_mtrl_am_alpha"
                        android:padding="8dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnProfilePreviewVib"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Preview" android:layout_marginTop="12dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Vibration timeout -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp" app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Vibration Timeout"
                            android:textSize="16sp" android:textColor="@color/textPrimary"
                            android:fontFamily="sans-serif-medium" />
                        <TextView android:id="@+id/tvProfileVibTimeoutLabel"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="1 min" android:textSize="14sp"
                            android:textColor="@color/colorPrimary" android:textStyle="bold" />
                    </LinearLayout>
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderProfileVibTimeout"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:valueFrom="0" android:valueTo="900" android:stepSize="15" android:value="60"
                        app:thumbColor="@color/colorPrimary" app:trackColorActive="@color/colorPrimary" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="No timeout" android:textSize="10sp" android:textColor="#9E9E9E"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15 min" android:textSize="10sp" android:textColor="#9E9E9E"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ ACTION (Notice profile only) ══════════════════════════ -->
            <LinearLayout
                android:id="@+id/layoutActionSection"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="ACTION"
                    android:textSize="11sp" android:letterSpacing="0.12"
                    android:textColor="@color/colorPrimary" android:fontFamily="sans-serif-medium"
                    android:paddingBottom="6dp" />
                <TextView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="One-shot sounds played at phase transitions. Volume applied at system level."
                    android:textSize="12sp" android:textColor="@color/textSecondary"
                    android:paddingBottom="12dp" />

                <!-- Delay sound -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp" app:cardElevation="2dp"
                    app:cardBackgroundColor="@android:color/white">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="20dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Delay Sound"
                                    android:textSize="16sp" android:textColor="@color/textPrimary"
                                    android:fontFamily="sans-serif-medium" />
                                <TextView android:id="@+id/tvDelaySoundName"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="System notification tone"
                                    android:textSize="13sp" android:textColor="@color/textSecondary"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnPickDelaySound"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Choose"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                        </LinearLayout>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Played once when delay ends and task timer begins"
                            android:textSize="12sp" android:textColor="@color/textSecondary"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Rest sound -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp" app:cardElevation="2dp"
                    app:cardBackgroundColor="@android:color/white">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="20dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Rest Sound"
                                    android:textSize="16sp" android:textColor="@color/textPrimary"
                                    android:fontFamily="sans-serif-medium" />
                                <TextView android:id="@+id/tvRestSoundName"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="System notification tone"
                                    android:textSize="13sp" android:textColor="@color/textSecondary"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnPickRestSound"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Choose"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                        </LinearLayout>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Played once when rest phase begins"
                            android:textSize="12sp" android:textColor="@color/textSecondary"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Action volume -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="12dp" app:cardElevation="2dp"
                    app:cardBackgroundColor="@android:color/white">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="20dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="Action Volume"
                                android:textSize="16sp" android:textColor="@color/textPrimary"
                                android:fontFamily="sans-serif-medium" />
                            <TextView android:id="@+id/tvActionVolumeLabel"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="80%" android:textSize="14sp"
                                android:textColor="@color/colorPrimary" android:textStyle="bold" />
                        </LinearLayout>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="System notification volume for delay &amp; rest sounds. Restored after playback."
                            android:textSize="12sp" android:textColor="@color/textSecondary"
                            android:layout_marginTop="2dp" android:layout_marginBottom="8dp" />
                        <com.google.android.material.slider.Slider
                            android:id="@+id/sliderActionVolume"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:valueFrom="0" android:valueTo="100" android:stepSize="5" android:value="80"
                            app:thumbColor="@color/colorPrimary" app:trackColorActive="@color/colorPrimary" />
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0%" android:textSize="10sp" android:textColor="#9E9E9E"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100%" android:textSize="10sp" android:textColor="#9E9E9E"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout><!-- end layoutActionSection -->

        </LinearLayout>
    </ScrollView>
</LinearLayout>
