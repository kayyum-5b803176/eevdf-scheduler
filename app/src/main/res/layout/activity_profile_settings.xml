<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/profileSettingsToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/white"
        android:elevation="4dp"
        app:titleTextColor="@color/textPrimary" />

    <!-- Tab strip to switch between profiles -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/profileTabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabSelectedTextColor="@color/colorPrimary"
        app:tabIndicatorColor="@color/colorPrimary"
        app:tabTextColor="@color/textSecondary" />

    <ScrollView
        android:id="@+id/profileScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- ── SOUND section ─────────────────────────────────────────── -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SOUND"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:textColor="@color/colorPrimary"
                android:fontFamily="sans-serif-medium"
                android:paddingBottom="12dp" />

            <!-- Sound picker card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Timer Sound"
                                android:textSize="16sp"
                                android:textColor="@color/textPrimary"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvProfileSoundName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="System alarm tone"
                                android:textSize="13sp"
                                android:textColor="@color/textSecondary"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnProfilePickSound"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Choose"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Sound timeout card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Sound Timeout"
                            android:textSize="16sp"
                            android:textColor="@color/textPrimary"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tvProfileSoundTimeoutLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1 min"
                            android:textSize="14sp"
                            android:textColor="@color/colorPrimary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="How long sound plays after timer expires (0 = no timeout)"
                        android:textSize="12sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderProfileSoundTimeout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="900"
                        android:stepSize="15"
                        android:value="60"
                        app:thumbColor="@color/colorPrimary"
                        app:trackColorActive="@color/colorPrimary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="No timeout" android:textSize="10sp" android:textColor="#9E9E9E"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="15 min" android:textSize="10sp" android:textColor="#9E9E9E"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Volume card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Default Volume"
                            android:textSize="16sp"
                            android:textColor="@color/textPrimary"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tvProfileVolumeLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="80%"
                            android:textSize="14sp"
                            android:textColor="@color/colorPrimary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Alarm rings at this volume. Returns to previous level when stopped."
                        android:textSize="12sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderProfileVolume"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="100"
                        android:stepSize="5"
                        android:value="80"
                        app:thumbColor="@color/colorPrimary"
                        app:trackColorActive="@color/colorPrimary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="0%" android:textSize="10sp" android:textColor="#9E9E9E"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="100%" android:textSize="10sp" android:textColor="#9E9E9E"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Fade-in card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Gradual Volume Increase"
                            android:textSize="16sp"
                            android:textColor="@color/textPrimary"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tvProfileFadeInLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Off"
                            android:textSize="14sp"
                            android:textColor="@color/colorPrimary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Slowly increase from silent to target volume (0 = start at full volume)"
                        android:textSize="12sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderProfileFadeIn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="300"
                        android:stepSize="15"
                        android:value="0"
                        app:thumbColor="@color/colorPrimary"
                        app:trackColorActive="@color/colorPrimary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Off" android:textSize="10sp" android:textColor="#9E9E9E"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="5 min" android:textSize="10sp" android:textColor="#9E9E9E"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Action 1 card (NOTIFICATION profile only) ─────────────── -->
            <!-- Shown only when the Notification tab is active (toggled in code) -->

            <LinearLayout
                android:id="@+id/layoutAction1Section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ACTION 1  —  TIMER START CUE"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textColor="@color/colorPrimary"
                    android:fontFamily="sans-serif-medium"
                    android:paddingBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Played once when the delay ends and the task timer begins. No vibration."
                    android:textSize="12sp"
                    android:textColor="@color/textSecondary"
                    android:paddingBottom="12dp" />

                <!-- Action 1 sound picker -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@android:color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Cue Sound"
                                    android:textSize="16sp"
                                    android:textColor="@color/textPrimary"
                                    android:fontFamily="sans-serif-medium" />

                                <TextView
                                    android:id="@+id/tvAction1SoundName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="System notification tone"
                                    android:textSize="13sp"
                                    android:textColor="@color/textSecondary"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnAction1PickSound"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Choose"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Action 1 volume -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@android:color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Cue Volume"
                                android:textSize="16sp"
                                android:textColor="@color/textPrimary"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvAction1VolumeLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="80%"
                                android:textSize="14sp"
                                android:textColor="@color/colorPrimary"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <com.google.android.material.slider.Slider
                            android:id="@+id/sliderAction1Volume"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:valueFrom="0"
                            android:valueTo="100"
                            android:stepSize="5"
                            android:value="80"
                            app:thumbColor="@color/colorPrimary"
                            app:trackColorActive="@color/colorPrimary" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="0%" android:textSize="10sp" android:textColor="#9E9E9E"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="100%" android:textSize="10sp" android:textColor="#9E9E9E"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ── VIBRATION section (hidden for Notification profile) ──── -->
            <LinearLayout
                android:id="@+id/layoutVibrationSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="VIBRATION &amp; HAPTICS"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:textColor="@color/colorPrimary"
                android:fontFamily="sans-serif-medium"
                android:paddingBottom="12dp" />

            <!-- Vibration pattern card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Vibration Pattern"
                        android:textSize="16sp"
                        android:textColor="@color/textPrimary"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="12dp" />

                    <RadioGroup
                        android:id="@+id/rgProfileVibPattern"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnProfilePreviewVib"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Preview"
                        android:layout_marginTop="12dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Vibration timeout card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Vibration Timeout"
                            android:textSize="16sp"
                            android:textColor="@color/textPrimary"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tvProfileVibTimeoutLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1 min"
                            android:textSize="14sp"
                            android:textColor="@color/colorPrimary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="How long vibration continues after timer expires (0 = no timeout)"
                        android:textSize="12sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderProfileVibTimeout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="900"
                        android:stepSize="15"
                        android:value="60"
                        app:thumbColor="@color/colorPrimary"
                        app:trackColorActive="@color/colorPrimary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="No timeout" android:textSize="10sp" android:textColor="#9E9E9E"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="15 min" android:textSize="10sp" android:textColor="#9E9E9E"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Haptic feedback card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchProfileHaptic"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Haptic Feedback on Buttons"
                        android:textSize="16sp"
                        android:checked="true" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Short vibration on every UI button tap"
                        android:textSize="12sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            </LinearLayout><!-- end layoutVibrationSection -->

        </LinearLayout>
    </ScrollView>
</LinearLayout>
