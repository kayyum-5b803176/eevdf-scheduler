<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/uiCustomizationToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/white"
        android:elevation="4dp"
        app:titleTextColor="@color/textPrimary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- ══ SIMPLE MODE ═════════════════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SIMPLE MODE"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:textColor="@color/colorPrimary"
                android:fontFamily="sans-serif-medium"
                android:paddingBottom="12dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchSimpleMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Simple Mode"
                        android:textSize="16sp"
                        android:textColor="@color/textPrimary"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Unselected cards show name only. Tap to expand. Running task stays expanded."
                        android:textSize="12sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="4dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ UNIT FORMAT ══════════════════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="UNIT FORMAT"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:textColor="@color/colorPrimary"
                android:fontFamily="sans-serif-medium"
                android:paddingBottom="12dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchUnitFormat"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="SI Unit Format"
                        android:textSize="16sp"
                        android:textColor="@color/textPrimary"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="VRT, VDL, Runs, TRT use SI suffixes. Floats: 88191 → 88.19K. Integers: 1800 → 1.8K. Time: 3d 28h 3s → 3d 28h."
                        android:textSize="12sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="4dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ CARD HEIGHT ══════════════════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CARD HEIGHT"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:textColor="@color/colorPrimary"
                android:fontFamily="sans-serif-medium"
                android:paddingBottom="12dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Card Height"
                            android:textSize="16sp"
                            android:textColor="@color/textPrimary"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tvCardHeightValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5 (Default)"
                            android:textSize="14sp"
                            android:textColor="@color/colorPrimary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Adjusts card padding. Font size unchanged."
                        android:textSize="12sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderCardHeight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="1"
                        android:valueTo="5"
                        android:stepSize="1"
                        android:value="5"
                        app:thumbColor="@color/colorPrimary"
                        app:trackColorActive="@color/colorPrimary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Compact"
                            android:textSize="10sp"
                            android:textColor="@color/textSecondary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Default"
                            android:textSize="10sp"
                            android:textColor="@color/textSecondary" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ WINDOW CALIBRATE ═════════════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="WINDOW CALIBRATE"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:textColor="@color/colorPrimary"
                android:fontFamily="sans-serif-medium"
                android:paddingBottom="12dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Toggle -->
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchAutoAdjust"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Window Calibrate"
                        android:textSize="16sp"
                        android:textColor="@color/textPrimary"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Hides stat rows on FLOAT / MINI profiles. NORMAL keeps full layout."
                        android:textSize="12sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="4dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="10dp"
                        android:background="@color/divider" />

                    <!-- Live window stats -->
                    <TextView
                        android:id="@+id/tvWindowLiveStats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="reading…"
                        android:textSize="10sp"
                        android:textColor="#E65100"
                        android:fontFamily="monospace"
                        android:background="#FFF3E0"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="10dp"
                        android:background="@color/divider" />

                    <!-- Calibrate Profiles header -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="CALIBRATE PROFILES"
                        android:textSize="10sp"
                        android:letterSpacing="0.12"
                        android:textColor="@color/colorPrimary"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp" />

                    <!-- 3-column profile picker -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- FLOAT profile card -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardCalFloat"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="1dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="10dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="FLOAT"
                                    android:textSize="11sp"
                                    android:textColor="@color/colorPrimary"
                                    android:fontFamily="sans-serif-medium" />
                                <TextView
                                    android:id="@+id/tvCalFloatDims"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="not set"
                                    android:textSize="10sp"
                                    android:textColor="@color/textSecondary"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="monospace" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- NORMAL profile card -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardCalNormal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="4dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="1dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="10dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="NORMAL"
                                    android:textSize="11sp"
                                    android:textColor="@color/colorPrimary"
                                    android:fontFamily="sans-serif-medium" />
                                <TextView
                                    android:id="@+id/tvCalNormalDims"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="not set"
                                    android:textSize="10sp"
                                    android:textColor="@color/textSecondary"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="monospace" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- MINI profile card -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardCalMini"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="1dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="10dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="MINI"
                                    android:textSize="11sp"
                                    android:textColor="@color/colorPrimary"
                                    android:fontFamily="sans-serif-medium" />
                                <TextView
                                    android:id="@+id/tvCalMiniDims"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="not set"
                                    android:textSize="10sp"
                                    android:textColor="@color/textSecondary"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="monospace" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <!-- Hint -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tap to record · Long-press to clear"
                        android:textSize="11sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="8dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
