<?xml version="1.0" encoding="utf-8"?>
<!--
  Category card — searchable autocomplete text input.
  Suggestions drawn live from TaskDao.getDistinctCategories().
  Wired in AddTaskCategoryPrioritySection.kt :: setupCategoryInput().
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:layout_marginBottom="12dp" />

        <!--
          OutlinedBox wraps MaterialAutoCompleteTextView instead of TextInputEditText.
          MaterialAutoCompleteTextView does NOT inherit the same default padding that
          TextInputEditText receives from the OutlinedBox style, so we set it explicitly:
            paddingStart/End = 16dp  → matches TextInputEditText lateral padding
            paddingTop/Bottom = 16dp → keeps text vertically centred inside the stroke
          Without these the text baseline sits on or outside the bottom stroke and
          there is no gap between the first character and the left border.
        -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCategoryInput"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Type or select a category">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/etCategoryInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:completionThreshold="1"
                android:inputType="textCapWords"
                android:imeOptions="actionDone"
                android:maxLines="1"
                android:singleLine="true" />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
