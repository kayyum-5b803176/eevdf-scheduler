<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardTask"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Running indicator bar -->
        <View
            android:id="@+id/viewRunningIndicator"
            android:layout_width="5dp"
            android:layout_height="match_parent"
            android:background="@color/colorAccent"
            android:visibility="invisible" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Row 1: Rank + Name + Category + Priority badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvRank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#1"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvTaskName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Task Name"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#212121"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tvCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="General"
                        android:textSize="11sp"
                        android:textColor="#9E9E9E" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvPriority"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Priority: 5/10"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Progress bar -->
            <ProgressBar
                android:id="@+id/progressTask"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/colorPrimary"
                android:progressBackgroundTint="#E0E0E0" />

            <!-- Row 2: Time info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tvTimeSlice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TRT: 0s"
                    android:textSize="12sp"
                    android:textColor="#616161" />

                <TextView
                    android:id="@+id/tvRemaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="25:00"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Row 3: EEVDF metrics -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tvVruntime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="VRT: 0.00"
                    android:textSize="10sp"
                    android:textColor="#BDBDBD" />

                <TextView
                    android:id="@+id/tvVdeadline"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="VDL: 0.00"
                    android:textSize="10sp"
                    android:textColor="#BDBDBD" />

                <TextView
                    android:id="@+id/tvRunCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Runs: 0"
                    android:textSize="10sp"
                    android:textColor="#BDBDBD" />
            </LinearLayout>

            <!-- Row 4: Action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="end">

                <ImageButton
                    android:id="@+id/btnRevert"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_undo_24"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#7E57C2"
                    android:contentDescription="Revert to Queue"
                    android:visibility="gone" />

                <ImageButton
                    android:id="@+id/btnResetSlice"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/outline_rotate_left_24"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#FF9800"
                    android:contentDescription="Reset Timer Slice"
                    android:visibility="gone" />

                <!-- Group expand/collapse (visible for group items only) -->
                <ImageButton
                    android:id="@+id/btnGroupToggle"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/outline_arrow_circle_down_24"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/colorPrimary"
                    android:contentDescription="Toggle Group"
                    android:visibility="gone" />

                <ImageButton
                    android:id="@+id/btnRun"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/outline_timer_play_24"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/colorPrimary"
                    android:contentDescription="Run Task" />

                <ImageButton
                    android:id="@+id/btnComplete"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/outline_check_circle_24"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#4CAF50"
                    android:contentDescription="Mark Complete" />

                <ImageButton
                    android:id="@+id/btnDelete"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/baseline_delete_24"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#F44336"
                    android:contentDescription="Delete" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
