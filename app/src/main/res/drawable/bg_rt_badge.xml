<?xml version="1.0" encoding="utf-8"?>
<!--
  Pill-shaped background for the RT scheduler window badge on task cards.
  The fill colour is set programmatically in TaskAdapter:
    Active  (inside window)   → #1B5E20  deep-green
    Pending (window upcoming) → #78909C  blue-grey
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#1B5E20" />
    <corners android:radius="10dp" />
</shape>
