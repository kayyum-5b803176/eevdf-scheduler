<?xml version="1.0" encoding="utf-8"?>
<!--
    Small circle used as the sync status dot overlaid on the sync toolbar icon.
    Default fill is gray (disabled / idle).  MainActivity overrides the tint at
    runtime based on SyncState.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="#9E9E9E" />
    <stroke android:width="1dp" android:color="#00000033" />
</shape>
