<?xml version="1.0" encoding="utf-8"?>
<!--
    Background for the floating call-state bubble.
    Dark semi-transparent fill so the bubble is legible over any wallpaper or app.
    Thin white stroke gives it a floating "pill" quality similar to the AOSP phone bubble.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="#CC1A1A1A" />
    <stroke android:width="1.5dp" android:color="#44FFFFFF" />
</shape>
